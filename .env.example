# ──────────────────────────────────────────────────────────────
# Lumen edgenet node
# ──────────────────────────────────────────────────────────────

# Binary name (lumend for mainnet based edgenet, lumentestd for testnet based)
BINARY=lumend

# Chain identifier of the network the edgenet is derived from
CHAIN_ID=lumen-1

# Token denominations
DENOM=ualpha
STAKE_DENOM=usync

# Platform of the prebuilt binary to download (x86_64 or arm64)
PLATFORM=x86_64

# Mnemonic of the edgenet validator account
VALIDATOR_MNEMONIC=

# URL of the chain snapshot archive (.tar.lz4) restored on startup
SNAPSHOT_URL=https://snapshot.lumen.euclidprotocol.com/api/snapshots/latest/download

# ──────────────────────────────────────────────────────────────
# Anvil forks
#
# Every anvil service takes its upstream RPC endpoint and its block
# time from this file. Adding a chain means adding one
# <NAME>_FORK_RPC_URL line, one <NAME>_BLOCK_TIME_MS line, and one
# service block in docker-compose.yml.
# ──────────────────────────────────────────────────────────────

# Snapshot API consumed by scripts/anvil-fork.sh
SNAPSHOT_API_URL=https://snapshot.lumen.euclidprotocol.com/api

# Upstream RPC endpoint forked by each anvil service.
BASE_FORK_RPC_URL=https://mainnet.base.org
SOMNIA_FORK_RPC_URL=https://api.infra.mainnet.somnia.network

# Milliseconds between mined blocks on each fork. This is a nominal
# average only. The resolver self-corrects for drift, so a rough value
# is fine (order of magnitude matters, exactness does not).
BASE_BLOCK_TIME_MS=2000
SOMNIA_BLOCK_TIME_MS=1000
