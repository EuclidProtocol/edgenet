# ──────────────────────────────────────────────────────────────
# Lumen edgenet node
# ──────────────────────────────────────────────────────────────

# Binary name (lumend for mainnet based edgenet, lumentestd for testnet based)
BINARY=lumend

# Chain identifier of the network the edgenet is derived from
CHAIN_ID=lumen-1

# Token denominations
DENOM=ualpha
STAKE_DENOM=usync

# Platform of the prebuilt binary to download (x86_64 or arm64)
PLATFORM=x86_64

# Mnemonic of the edgenet validator account
VALIDATOR_MNEMONIC=

# URL of the snapshot metadata endpoint queried on startup
SNAPSHOT_URL=https://snapshot.lumen.euclidprotocol.com/api/snapshots/latest

# Comma separated list of extra bech32 addresses to fund on the testnet,
# beyond the validator's own account, which is always funded. Leave empty
# to fund only the validator.
FUNDED_ACCOUNTS=euclid1z328t58xya5hw32a869n6hah33uaehw5zz9rj3

# ──────────────────────────────────────────────────────────────
# Anvil forks
#
# Every anvil service takes its upstream RPC endpoint and its fork
# block height from this file. Adding a chain means adding one
# <NAME>_FORK_RPC_URL line, one <NAME>_FORK_BLOCK line, and one
# service block in docker-compose.yml.
# ──────────────────────────────────────────────────────────────

# Upstream RPC endpoint forked by each anvil service.
BASE_FORK_RPC_URL=https://mainnet.base.org
SOMNIA_FORK_RPC_URL=https://api.infra.mainnet.somnia.network

# Block height each anvil service forks at. Leave empty to fork the
# chain tip (the default for a fresh clone). Set to a positive integer
# to pin a specific block.
BASE_FORK_BLOCK=
SOMNIA_FORK_BLOCK=
